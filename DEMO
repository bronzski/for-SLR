            cursor: pointer;
            background: #f8f9fa;
        }
        .upload-area img {
            max-width: 100%;
            max-height: 200px;
            border-radius: 0.5rem;
            margin-top: 0.5rem;
        }
        .list-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.7rem 0;
            border-bottom: 1px solid #dee2e6;
        }
        .text-muted { color: #6c757d; font-size: 0.9rem; }
        .timer { font-weight: bold; font-size: 1.2rem; margin: 0.5rem 0; }
        .green-dot { color: var(--success); font-weight: bold; }
        .red-dot { color: var(--danger); font-weight: bold; }
        .photo-thumb { display: inline-block; width: 80px; height: 80px; object-fit: cover; border-radius: 0.5rem; margin: 0.3rem; border: 1px solid #ddd; }
        .sticky-top {
            position: sticky;
            top: 0;
            background: white;
            z-index: 10;
            padding-bottom: 0.5rem;
        }
        @media (max-width: 480px) {
            body { padding: 0; }
            .app-container { border-radius: 0; min-height: 100vh; }
            .btn { padding: 1rem; font-size: 1.1rem; }
        }
    </style>
</head>
<body>
<div class="app-container" id="app">
    <div class="header">🏭 Склад SLR (ФДН 10) — Приёмка</div>
    <div class="content" id="content"></div>
</div>

<script>
    // Состояние
    const state = {
        step: 'start',
        receiptNumber: null,
        userId: 'Кладовщик_Иванов',
        startTime: null,
        defectsPackaging: false,
        packagingPhotos: [],
        unloadStart: null,
        unloadEnd: null,
        docImages: [],
        parsedDoc: null,        // { supplier, docNumber, docDate, items: [{id, name, article, qty, unit}] }
        scannedItems: [],      // id подтверждённых позиций
        qualityResults: {},    // id -> {defect: bool, photos: []}
        placementMap: {},
    };

    let receiptCounter = 1;

    function generateReceiptNumber() {
        const now = new Date();
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const year = now.getFullYear();
        const num = String(receiptCounter++).padStart(3, '0');
        return `П-${month}${year}-${num}`;
    }

    function render(html) {
        document.getElementById('content').innerHTML = html;
    }

    // ---------- Шаги ----------
    function startScreen() {
        state.receiptNumber = generateReceiptNumber();
        state.step = 'start';
        render(`
            <div style="text-align:center;">
                <h3>👋 Добро пожаловать, ${state.userId}</h3>
                <p class="text-muted">Новая поставка №${state.receiptNumber}</p>
                <button class="btn btn-primary" onclick="stepPackaging()">🚚 Начать приёмку</button>
            </div>
        `);
    }

    function stepPackaging() {
        state.step = 'packaging';
        state.packagingPhotos = [];
        render(`
            <div class="step-indicator"><span>1/7</span> Осмотр упаковок</div>
            <div class="instruction">Осмотри груз в машине.</div>
            <p>Есть ли повреждения упаковок?</p>
            <div class="btn-group">
                <button class="btn btn-outline" onclick="packagingDefectYes()">✅ Да, есть дефекты</button>
                <button class="btn btn-outline" onclick="packagingDefectNo()">❌ Нет, всё целое</button>
            </div>
        `);
    }

    function packagingDefectYes() {
        state.defectsPackaging = true;
        showCameraUpload('Сфотографируйте дефекты упаковки', (files) => {
            state.packagingPhotos = files.map(f => URL.createObjectURL(f));
            render(`
                <div class="step-indicator"><span>1/7</span> Осмотр упаковок</div>
                <div class="instruction">Дефекты зафиксированы</div>
                <div style="margin:1rem 0;">
                    ${state.packagingPhotos.map(url => `<img src="${url}" class="photo-thumb" onclick="window.open('${url}')">`).join('')}
                </div>
                <button class="btn btn-primary" onclick="stepUnload()">▶️ Продолжить</button>
            `);
        }, true);
    }

    function packagingDefectNo() {
        state.defectsPackaging = false;
        stepUnload();
    }

    function stepUnload() {
        state.step = 'unload';
        state.unloadStart = new Date();
        render(`
            <div class="step-indicator"><span>2/7</span> Выгрузка</div>
            <div class="instruction">Выгружайте товар из машины.</div>
            <div class="timer" id="unloadTimer">00:00:00</div>
            <button class="btn btn-primary" onclick="finishUnload()">🏁 Завершить выгрузку</button>
        `);
        window.unloadInterval = setInterval(() => {
            const diff = Math.floor((new Date() - state.unloadStart) / 1000);
            const h = String(Math.floor(diff/3600)).padStart(2,'0');
            const m = String(Math.floor((diff%3600)/60)).padStart(2,'0');
            const s = String(diff%60).padStart(2,'0');
            const el = document.getElementById('unloadTimer');
            if(el) el.textContent = `${h}:${m}:${s}`;
        }, 1000);
    }

    function finishUnload() {
        clearInterval(window.unloadInterval);
        state.unloadEnd = new Date();
        stepScanDocument();
    }

    function stepScanDocument() {
        state.step = 'scan_doc';
        state.docImages = [];
        state.parsedDoc = null;
        render(`
            <div class="step-indicator"><span>3/7</span> Сканирование документа</div>
            <div class="instruction">Сфотографируйте все страницы счёта / УПД.</div>
            <div id="docPreview" class="upload-area" onclick="triggerDocPhoto()">
                📄 Нажмите, чтобы добавить страницу
                <div id="docThumbs"></div>
            </div>
            <button class="btn btn-primary" id="ocrBtn" onclick="performOCR()">🔍 Завершить и распознать</button>
            <div id="ocrStatus" style="text-align:center; color:#6c757d;"></div>
        `);
    }

    function triggerDocPhoto() {
        showCameraUpload('Фото страницы документа', (files) => {
            const file = files[0];
            state.docImages.push(file);
            const thumb = document.getElementById('docThumbs');
            const img = document.createElement('img');
            img.src = URL.createObjectURL(file);
            img.style.maxWidth = '100px'; img.style.margin = '0.3rem';
            thumb.appendChild(img);
        });
    }

    // ---- OCR + парсинг ----
    async function performOCR() {
        if (state.docImages.length === 0) {
            alert('Сделайте хотя бы одно фото.');
            return;
        }
        const statusDiv = document.getElementById('ocrStatus');
        const btn = document.getElementById('ocrBtn');
        btn.disabled = true;
        statusDiv.textContent = '⏳ Распознавание...';

        let fullText = '';
        for (let i = 0; i < state.docImages.length; i++) {
            const file = state.docImages[i];
            const imageUrl = URL.createObjectURL(file);
            try {
                const { data: { text } } = await Tesseract.recognize(imageUrl, 'rus+eng', {
                    logger: m => {
                        if (m.status === 'recognizing text') {
                            statusDiv.textContent = `🔎 Страница ${i+1}: ${Math.round(m.progress * 100)}%`;
                        }
                    }
                });
                fullText += text + '\n';
            } catch (e) {
                alert('Ошибка распознавания. Попробуйте ещё раз.');
                btn.disabled = false;
                return;
            }
        }

        statusDiv.textContent = '✅ Текст распознан. Извлекаем данные...';
        // Постобработка: исправление типичных ошибок OCR
        fullText = applyOCRFixes(fullText);
        const parsed = parseDocumentText(fullText);
        if (parsed && parsed.items.length > 0) {
            state.parsedDoc = parsed;
            stepVerifyLabels();
        } else {
            alert('Не удалось найти товарные позиции. Убедитесь в хорошем качестве фото (свет, фокус) и повторите.');
            btn.disabled = false;
        }
    }

    // Замена частых ошибок OCR на основе словаря и эвристик
    function applyOCRFixes(text) {
        let fixed = text;
        // Типичные замены (пара буква -> правильная)
        const replacements = {
            'Лверь': 'Дверь',
            'лверь': 'дверь',
            'Стекло': 'Стекло', // бывает путаница с латинской C
            'с?текло': 'стекло',
            '5': '5', // цифра 5 может быть распознана как S, но исправлять сложно, оставим
            '0': '0',
        };
        // Применим только для слов, которые есть в нашем мини-словаре
        const knownWords = ['дверь', 'бампер', 'фара', 'зеркало', 'стекло', 'капот', 'крыло', 'радиатор', 'решётка'];
        // Простая замена: ищем слова, похожие на известные с одной ошибкой
        const words = fixed.split(/(\s+)/);
        for (let i = 0; i < words.length; i++) {
            const w = words[i].toLowerCase();
            if (knownWords.includes(w)) continue;
            // Попытка найти близкое известное слово (расстояние Левенштейна 1)
            for (let kw of knownWords) {
                if (levenshteinDistance(w, kw) <= 1) {
                    words[i] = words[i].replace(w, kw); // сохраняем регистр? пусть будет оригинальный
                    break;
                }
            }
        }
        fixed = words.join('');
        return fixed;
    }

    function levenshteinDistance(a, b) {
        const m = a.length, n = b.length;
        const dp = Array.from({ length: m+1 }, () => Array(n+1).fill(0));
        for (let i = 0; i <= m; i++) dp[i][0] = i;
        for (let j = 0; j <= n; j++) dp[0][j] = j;
        for (let i = 1; i <= m; i++) {
            for (let j = 1; j <= n; j++) {
                dp[i][j] = Math.min(
                    dp[i-1][j] + 1,
                    dp[i][j-1] + 1,
                    dp[i-1][j-1] + (a[i-1] === b[j-1] ? 0 : 1)
                );
            }
        }
        return dp[m][n];
    }

    function parseDocumentText(text) {
        const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 0);
        // Шапка: ищем поставщика, номер, дату
        const supplierPatterns = [/Поставщик:?\s*(.+)/i, /ООО\s*".+?"/, /ИП\s+.+/];
        const docNumberPatterns = [/(?:Счёт|УПД|№)\s*[№#]?\s*([\d\-]+)/i, /(?:Счет|Счёт-фактура)\s*[№#]?\s*([\d\-]+)/i];
        const datePattern = /от\s*(\d{2}\.\d{2}\.\d{4}|\d{4}-\d{2}-\d{2})/;

        let supplier = '', docNumber = '', docDate = '';
        for (let line of lines) {
            for (let p of supplierPatterns) {
                let m = line.match(p);
                if (m) { supplier = m[1] || m[0]; break; }
            }
            for (let p of docNumberPatterns) {
                let m = line.match(p);
                if (m) { docNumber = m[1]; break; }
            }
            let dm = line.match(datePattern);
            if (dm) docDate = dm[1];
        }
        if (!supplier) supplier = 'Неизвестный поставщик';
        if (!docNumber) docNumber = 'б/н';
        if (!docDate) docDate = new Date().toLocaleDateString();

        // Табличная часть: ищем строки, содержащие артикул (минимум 5 символов, буквы/цифры/дефис) и количество (число + единица)
        const items = [];
        const articleRegex = /([A-Za-z0-9\-]{5,})/;
        const qtyRegex = /(\d+)\s*(шт|ед|компл|л|кг|м)/i;
        const skipKeywords = ['поставщик', 'покупатель', 'адрес', 'телефон', 'инн', 'кпп', 'р/с', 'банк', 'директор', 'менеджер'];

        for (let line of lines) {
            // Пропускаем строки, содержащие явно не товарные данные
            if (skipKeywords.some(kw => line.toLowerCase().includes(kw))) continue;
            const articleMatch = line.match(articleRegex);
            const qtyMatch = line.match(qtyRegex);
            if (articleMatch) {
                const article = articleMatch[1].toUpperCase();
                // Если уже есть такой артикул, пропускаем (дубликат)
                if (items.find(i => i.article === article)) continue;
                // Количество
                let qty = 1;
                let unit = 'шт';
                if (qtyMatch) {
                    qty = parseInt(qtyMatch[1]) || 1;
                    unit = qtyMatch[2] || 'шт';
                }
                // Название – всё, что до артикула, или после него, но не число
                const parts = line.split(articleMatch[1]);
                let name = parts[0].trim();
                if (!name) name = parts[1] ? parts[1].trim() : 'Товар';
                // Убираем возможные единицы измерения и числа из названия
                name = name.replace(/\d+\s*(шт|ед|компл).*/i, '').trim();
                if (!name) name = 'Товар';
                items.push({
                    id: items.length + 1,
                    name: name,
                    article: article,
                    qty: qty,
                    unit: unit
                });
            }
        }

        return { supplier, docNumber, docDate, items };
    }

    // ---- Сверка этикеток (кнопка вверху) ----
    function stepVerifyLabels() {
        state.step = 'verify_labels';
        state.scannedItems = [];
        const doc = state.parsedDoc;
        if (!doc) return startScreen();

        render(`
            <div class="step-indicator"><span>4/7</span> Сверка этикеток</div>
            <div class="sticky-top">
                <div class="instruction">Сканируйте этикетки товаров</div>
                <button class="btn btn-primary" id="scanLabelBtn" onclick="scanLabel()">📸 Сканировать этикетку</button>
                <p style="text-align:center; margin:0.5rem 0;">Ожидается: ${doc.items.length} | Подтверждено: <span id="scannedCount">0</span></p>
            </div>
            <div id="labelList">
                ${doc.items.map(item => `
                    <div id="item-${item.id}" class="list-item" style="border-left: 4px solid #dc3545;">
                        <div><strong>${item.name}</strong><br><small>Арт: ${item.article} | ${item.qty} ${item.unit}</small></div>
                        <span id="status-${item.id}" class="red-dot">⏳</span>
                    </div>
                `).join('')}
            </div>
            <button class="btn btn-secondary" onclick="finishLabelCheck()">✅ Все этикетки отсканированы</button>
        `);
    }

    async function scanLabel() {
        showCameraUpload('Сфотографируйте этикетку', async (files) => {
            const file = files[0];
            const imageUrl = URL.createObjectURL(file);
            const btn = document.getElementById('scanLabelBtn');
            btn.disabled = true;
            btn.textContent = '🔎 Распознаю...';
            try {
                const { data: { text } } = await Tesseract.recognize(imageUrl, 'rus+eng', {
                    logger: m => {
                        if (m.status === 'recognizing text') {
                            btn.textContent = `🔎 ${Math.round(m.progress * 100)}%`;
                        }
                    }
                });
                // Ищем артикул в этикетке
                const articleMatch = text.match(/([A-Za-z0-9\-]{5,})/);
                if (articleMatch) {
                    const scannedArticle = articleMatch[1].toUpperCase();
                    const foundItem = state.parsedDoc.items.find(item => item.article.toUpperCase() === scannedArticle);
                    if (foundItem) {
                        if (!state.scannedItems.includes(foundItem.id)) {
                            state.scannedItems.push(foundItem.id);
                            const row = document.getElementById(`item-${foundItem.id}`);
                            if (row) row.style.borderLeft = '4px solid #198754';
                            const status = document.getElementById(`status-${foundItem.id}`);
                            if (status) status.innerHTML = '<span class="green-dot">✓</span>';
                            document.getElementById('scannedCount').textContent = state.scannedItems.length;
                        }
                        alert(`✓ "${foundItem.name}" подтверждена.`);
                    } else {
                        alert(`⚠️ Артикул "${scannedArticle}" не найден в документе.`);
                    }
                } else {
                    alert('Не удалось распознать артикул. Попробуйте ещё раз.');
                }
            } catch (e) {
                alert('Ошибка распознавания. Попробуйте ещё раз.');
            }
            btn.disabled = false;
            btn.textContent = '📸 Сканировать этикетку';
        });
    }

    function finishLabelCheck() {
        const doc = state.parsedDoc;
        const missing = doc.items.filter(item => !state.scannedItems.includes(item.id));
        if (missing.length > 0) {
            const list = missing.map(i => `❌ ${i.name} (арт. ${i.article})`).join('\n');
            const userChoice = confirm(`⚠️ Недостача:\n${list}\n\n"OK" — подтвердить и продолжить, "Отмена" — вернуться к сканированию.`);
            if (!userChoice) return;
        }
        alert('📤 Отправка в 1С: поступление и приходный ордер сформированы.');
        stepQualityControl();
    }

    // Остальные шаги (входной контроль, размещение) без изменений
    function stepQualityControl() {
        state.step = 'quality_control';
        const allItems = state.parsedDoc.items;
        const unchecked = allItems.filter(i => !(i.id in state.qualityResults));
        if (unchecked.length === 0) {
            stepPlacement();
            return;
        }
        const currentItem = unchecked[0];
        render(`
            <div class="step-indicator"><span>5/7</span> Входной контроль</div>
            <div class="instruction">Осмотрите: <strong>${currentItem.name}</strong></div>
            <p>Артикул: ${currentItem.article}</p>
            <button class="btn btn-success" onclick="qualityResult(${currentItem.id}, false)">✅ Дефектов нет</button>
            <button class="btn btn-danger" onclick="qualityResult(${currentItem.id}, true)">🔍 Обнаружен дефект</button>
        `);
    }

    function qualityResult(itemId, hasDefect) {
        if (hasDefect) {
            showCameraUpload('Сфотографируйте дефекты', (files) => {
                state.qualityResults[itemId] = { defect: true, photos: files.map(f => URL.createObjectURL(f)) };
                alert('Дефекты зафиксированы.');
                stepQualityControl();
            }, true);
        } else {
            state.qualityResults[itemId] = { defect: false, photos: [] };
            stepQualityControl();
        }
    }

    function stepPlacement() {
        state.step = 'placement';
        const allItems = state.parsedDoc.items;
        const unplaced = allItems.filter(i => !(i.id in state.placementMap));
        if (unplaced.length === 0) {
            finishReceipt();
            return;
        }
        const currentItem = unplaced[0];
        const defectInfo = state.qualityResults[currentItem.id];
        const isDefect = defectInfo && defectInfo.defect;
        render(`
            <div class="step-indicator"><span>6/7</span> Размещение</div>
            <div class="instruction">Разместите: <strong>${currentItem.name}</strong></div>
            ${isDefect ? '<p style="color:red;">⚠️ В ИЗОЛЯТОР БРАКА!</p>' : ''}
            <button class="btn btn-outline" onclick="scanLocation(${currentItem.id})">📸 Сканировать ячейку</button>
        `);
    }

    function scanLocation(itemId) {
        showCameraUpload('QR-код ячейки', (files) => {
            const location = prompt('Введите адрес ячейки:', 'B-12-3');
            state.placementMap[itemId] = { location: location || 'B-12-3' };
            alert(`Размещено в ${location}. Ярлык распечатан.`);
            stepPlacement();
        });
    }

    function finishReceipt() {
        state.step = 'done';
        const totalTime = state.unloadEnd ? Math.round((state.unloadEnd - state.unloadStart)/1000) : 0;
        render(`
            <div class="step-indicator"><span>7/7</span> Завершение</div>
            <div class="instruction">🎉 Приёмка №${state.receiptNumber} завершена!</div>
            <div class="card">
                <p><strong>Поставщик:</strong> ${state.parsedDoc.supplier}</p>
                <p><strong>Документ:</strong> ${state.parsedDoc.docNumber} от ${state.parsedDoc.docDate}</p>
                <p><strong>Позиций:</strong> ${state.parsedDoc.items.length}</p>
                <p><strong>Дефектных:</strong> ${Object.values(state.qualityResults).filter(v=>v.defect).length}</p>
                <p><strong>Время выгрузки:</strong> ${totalTime} сек</p>
            </div>
            <button class="btn btn-primary" onclick="startScreen()">🔄 Новая приёмка</button>
        `);
    }

    // Универсальный захват фото
    function showCameraUpload(promptText, callback, multiple = false) {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.capture = 'environment';
        if (multiple) input.multiple = true;
        input.onchange = (e) => {
            if (e.target.files.length > 0) {
                callback(Array.from(e.target.files));
            }
        };
        const msg = document.createElement('div');
        msg.style.cssText = 'position:fixed;top:0;left:0;width:100%;background:rgba(0,0,0,0.8);color:white;padding:2rem;text-align:center;z-index:9999;font-size:1.2rem;';
        msg.textContent = promptText + ' (нажмите для выбора)';
        document.body.appendChild(msg);
        input.click();
        input.addEventListener('change', () => document.body.removeChild(msg));
        input.addEventListener('cancel', () => document.body.removeChild(msg));
    }

    startScreen();
</script>
</body>
</html>
